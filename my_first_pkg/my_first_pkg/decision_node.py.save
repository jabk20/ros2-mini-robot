import rclpy
from rclpy.node import Node
from std_msgs.msg import Float32, String

class DecisionNode(Node):

    def __init__(self):
        super().__init__('decision_node')
        self.subscription = self.create_subscription(
            Float32,
            'distance',
            self.callback,
            10
        )
	self.publisher_= self.create_publisher(String, 'robot_action', 10)


    def callback(self, msg):
        distance = msg.data
	action_msg = String()

        if distance < 3.0:
            actionself.get_logger().info(f'🚨 STOP! Obstacle at {distance:.2f} m')
        else:
            self.get_logger().info(f'✅ MOVE: Clear ({distance:.2f} m)')

def main(args=None):
    rclpy.init(args=args)
    node = DecisionNode()
    rclpy.spin(node)
    node.destroy_node()
    rclpy.shutdown()
